# ─────────────────────────────────────────────────────────────────────────────
# SOS Nounous & Services — variables d'environnement (modèle)
# Copier ce fichier en `.env.local` et renseigner les valeurs réelles.
# AUCUN secret ne doit être committé (CDC §4.3 — sécurité).
# ─────────────────────────────────────────────────────────────────────────────

# URL publique du site (SEO, sitemap, liens absolus)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Coordonnées de contact affichées (à fournir par l'agence)
NEXT_PUBLIC_AGENCY_PHONE="+225 00 00 00 00"
NEXT_PUBLIC_AGENCY_EMAIL="contact@sosnounous.ci"

# ── Services externes — notifications (CDC §3.9 / §4.10) ──
# Mode des notifications : "mock" (console + journal, défaut) | "live" (envoi réel)
NOTIFICATIONS_MODE="mock"

# E-mail transactionnel via API HTTP (ex. Resend) — requis en prod si mode "live"
EMAIL_API_KEY=""
EMAIL_API_URL="https://api.resend.com/emails"
EMAIL_FROM="SOS Nounous & Services <no-reply@sosnounous.ci>"

# Passerelle SMS via API HTTP (OTP, alertes) — requis en prod si mode "live"
SMS_API_KEY=""
SMS_API_URL=""
SMS_SENDER="SOSNounous"

# ── Dépôt sécurisé de fichiers (CDC §4.4) ──
# Clé de chiffrement au repos des pièces justificatives (hex 32 octets).
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_ENCRYPTION_KEY=""
# Répertoire de stockage (hors web). Défaut : ./storage/uploads
# FILE_STORAGE_DIR="/var/data/sosnounous/uploads"

# ── Base de données (PostgreSQL — CDC §4.2) ──
# Le projet utilise PostgreSQL (dev & prod). En local : `docker compose up db`.
DATABASE_URL="postgresql://sosnounous:sosnounous@localhost:5432/sosnounous?schema=public"
